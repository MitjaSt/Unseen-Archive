{
  "manifest_version": 3,
  "name": "Unseen Archive",
  "key": "",
  "version": "1.0",
  "description": "Simple bookmarking app",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "apps/chrome-ext/src/service-worker/service-worker.js"
  },
  "action": {
    "default_title": "Click to open panel"
  },
  "commands": {
    "toggle": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Toggle panel"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel"]
}
